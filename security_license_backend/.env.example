# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-for-safety
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for development, PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/security_license_db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Crypto Master Key (generate a secure random key for production)
# openssl rand -base64 32
CRYPTO_MASTER_KEY=your-master-key-for-encrypting-private-keys-change-in-production

# Signing Keys Paths (optional, for system-wide signing)
SIGNING_PRIVATE_KEY_PATH=/path/to/private/key.pem
SIGNING_PUBLIC_KEY_PATH=/path/to/public/key.pem

# Email Configuration (Console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
